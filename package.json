{
  "name": "ghub",
  "version": "1.6.2",
  "description": "Multi-inbox Gmail MCP server with built-in OAuth onboarding",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ghub": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "start": "node dist/index.js",
    "reauth": "node scripts/reauth-gui.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "npm run build && node --test test/*.test.mjs",
    "postinstall": "node scripts/build-ocr.mjs"
  },
  "keywords": [
    "mcp",
    "gmail",
    "multi-inbox",
    "oauth",
    "model-context-protocol"
  ],
  "author": "Tyler Szakacs",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@types/express": "^5.0.6",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "google-auth-library": "^10.7.0",
    "googleapis": "^173.0.0",
    "mammoth": "^1.9.0",
    "officeparser": "^7.2.1",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "google-auth-library": "$google-auth-library",
    "uuid": "^11.1.1"
  }
}
